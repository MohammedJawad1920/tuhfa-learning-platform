    "@tanstack/react-query": "^5.100.9",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.35.4",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "iron-session": "^8.0.4",
    "next": "^16.0.0",
    "pino": "^9.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
